# SmartMeter Environment Variables Example
# Copier en tant que .env et remplir avec vos valeurs

# Django
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database - MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=smartmeter_db
DB_USER=smartmeteruser
# Recommended local dev password: 12345
DB_PASSWORD=your-local-password
DB_HOST=localhost
DB_PORT=3306

# JWT
ACCESS_TOKEN_LIFETIME=86400  # 24 hours in seconds
REFRESH_TOKEN_LIFETIME=604800  # 7 days in seconds

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
DJANGO_LOG_LEVEL=INFO

# Sentry (optionnel)
SENTRY_DSN=

# Email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password
