# SmartMeter Environment Variables Example
# Copier en tant que .env et remplir avec vos valeurs

# Django
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database - MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=smartmeter_db
DB_USER=smartmeteruser
# Recommended local dev password: 12345
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# JWT
ACCESS_TOKEN_LIFETIME=86400  # 24 hours in seconds
REFRESH_TOKEN_LIFETIME=604800  # 7 days in seconds

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
DJANGO_LOG_LEVEL=INFO

# ========================
# SPRINT 3: Hugging Face & Email
# ========================

# Hugging Face API Key (for anomaly detection - RG8)
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Email Configuration (for alerts - RG11)
# Using Gmail SMTP for example
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# For Gmail: Use App Password (not regular password)
# See: https://support.google.com/accounts/answer/185833
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@smartmeter.local

# Sentry (optionnel)
SENTRY_DSN=
