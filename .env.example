# SmartMeter Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real passwords to version control!

# ============================================================================
# Database Configuration (MySQL)
# ============================================================================
DB_ENGINE=django.db.backends.mysql
DB_NAME=smartmeter_db
DB_USER=smartmeter_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# MySQL-specific options
DB_OPTIONS_CHARSET=utf8mb4
DB_OPTIONS_STRICT_TRANS_TABLES=1
DB_CONN_MAX_AGE=600

# ============================================================================
# Django Configuration
# ============================================================================
DEBUG=True
SECRET_KEY=your-secret-key-here-min-50-chars-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# ============================================================================
# Django Settings
# ============================================================================
DJANGO_SETTINGS_MODULE=backend.settings

# ============================================================================
# JWT Configuration (if using JWT authentication)
# ============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# Email Configuration (for alerts and notifications)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@smartmeter.com

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/smartmeter.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================================================
# API Configuration
# ============================================================================
API_TIMEOUT=30
API_MAX_REQUESTS_PER_MINUTE=60

# ============================================================================
# ML/AI Configuration
# ============================================================================
ANOMALY_DETECTION_THRESHOLD=0.7
AI_MODEL_PATH=models/consumption_anomaly_model.pkl
AI_API_KEY=your-ai-api-key-if-using-external-service

# ============================================================================
# Security Settings
# ============================================================================
SECURE_SSL_REDIRECT=False  # Set to True in production
SESSION_COOKIE_SECURE=False  # Set to True in production
CSRF_COOKIE_SECURE=False  # Set to True in production
SECURE_HSTS_SECONDS=0  # Set to 31536000 in production
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# ============================================================================
# AWS/Cloud Configuration (optional)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# Cache Configuration (optional)
# ============================================================================
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_TIMEOUT=300

# Redis cache (if using Redis)
# CACHE_BACKEND=django_redis.cache.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1
# CACHE_OPTIONS={"CLIENT_CLASS": "django_redis.client.DefaultClient"}

# ============================================================================
# Celery Configuration (optional, for background tasks)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TIMEZONE=UTC

# ============================================================================
# Third-party Services
# ============================================================================
SENTRY_DSN=  # For error tracking
SLACK_WEBHOOK_URL=  # For Slack notifications

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_AI_ANALYSIS=True
ENABLE_ANOMALY_DETECTION=True
ENABLE_EMAIL_ALERTS=True
ENABLE_PUSH_NOTIFICATIONS=False

# ============================================================================
# Application Settings
# ============================================================================
APP_ENVIRONMENT=development  # development, staging, production
APP_VERSION=1.0.0
